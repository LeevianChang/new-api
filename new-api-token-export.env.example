# Copy this file to ./new-api-token-export.env on the server, then fill real values.
# Do not commit the real ./new-api-token-export.env file.

# Optional filter appended to the tokens export query.
# Examples:
# TOKEN_EXPORT_WHERE='status = 1'
# TOKEN_EXPORT_WHERE='used_quota > 0'
TOKEN_EXPORT_WHERE='status = 1'

# CSV output path inside the exporter container.
# With docker-compose, /data is mounted to the project's ./data directory.
TOKEN_EXPORT_OUTPUT_DIR='/data/token-exports'

# Performance tuning.
TOKEN_EXPORT_BATCH_SIZE='1000'
TOKEN_EXPORT_BATCH_SLEEP_MS='50'
TOKEN_EXPORT_TIMEOUT_MINUTES='30'

# Cloudflare R2.
R2_ACCOUNT_ID='your-cloudflare-account-id'
R2_ACCESS_KEY_ID='your-r2-access-key-id'
R2_SECRET_ACCESS_KEY='your-r2-secret-access-key'
R2_BUCKET='your-r2-bucket-name'
R2_OBJECT_PREFIX='daily/tokens'

# Public URL prefix for generated links.
# Example: https://files.example.com
# Leave empty if you only want the raw R2 S3 endpoint in the Feishu message.
R2_PUBLIC_BASE_URL='https://files.example.com'

# Feishu bot webhook.
FEISHU_WEBHOOK_URL='https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token'

# Optional keyword if the Feishu bot enables keyword validation.
FEISHU_KEYWORD='tokens导出'
