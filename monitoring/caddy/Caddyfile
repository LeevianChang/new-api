# 纯 HTTP 内网反代模式（雷池在前负责 HTTPS）
# 监听内网端口，不处理证书

:8080 {
  encode zstd gzip
  
  @api host {$API_DOMAIN}
  handle @api {
    reverse_proxy new-api:3000
  }
  
  @grafana host {$GRAFANA_DOMAIN}
  handle @grafana {
    reverse_proxy grafana:3000
  }
  
  @prometheus host {$PROMETHEUS_DOMAIN}
  handle @prometheus {
    reverse_proxy prometheus:9090
  }
  
  handle {
    respond "Invalid host" 404
  }
}
